{
  "experiment": "In-Context Learning: Chain-of-Thought vs Few-Shot Prompting",
  "configuration": {
    "model": "nvidia/nemotron-3-super-120b-a12b:free",
    "provider": "OpenRouter",
    "temperature": 0.0,
    "max_tokens": 1500,
    "samples_per_combination": 10,
    "metric": "Exact Match (EM)"
  },
  "results": [
    {
      "dataset": "gsm8k",
      "strategy": "standard_few_shot",
      "n": 10,
      "em": 90.0,
