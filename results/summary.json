  "pivot_em_by_strategy": {
    "standard_few_shot": {"gsm8k": 90.0, "strategyqa": 80.0},
    "zero_shot_cot":     {"gsm8k": 90.0, "strategyqa": 50.0},
    "persona_prompting": {"gsm8k": 80.0, "strategyqa": 50.0}
  }
