    {
      "dataset": "gsm8k",
      "strategy": "zero_shot_cot",
      "n": 10,
      "em": 90.0,
      "parse_failure_rate": 0.0
    },
    {
      "dataset": "gsm8k",
      "strategy": "persona_prompting",
      "n": 10,
      "em": 80.0,
      "parse_failure_rate": 0.0
    },
    {
      "dataset": "strategyqa",
      "strategy": "standard_few_shot",
      "n": 10,
      "em": 80.0,
      "parse_failure_rate": 10.0
    },
    {
      "dataset": "strategyqa",
      "strategy": "zero_shot_cot",
      "n": 10,
      "em": 50.0,
      "parse_failure_rate": 10.0
    },
    {
      "dataset": "strategyqa",
      "strategy": "persona_prompting",
      "n": 10,
      "em": 50.0,
      "parse_failure_rate": 10.0
